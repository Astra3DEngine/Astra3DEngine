{
  "name": "astra-3d-engine",
  "version": "0.1.0",
  "description": "A joking 3D engine",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": "Cyberexplorer",
  "homepage": "https://github.com/LanwyWriteXU/Astra3DEngine",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop": "vite --config vite.config.desktop.js",
    "desktop:build": "vite build --config vite.config.desktop.js && electron-builder",
    "desktop:preview": "electron dist-electron/main.js",
    "icon:generate": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "cannon-es": "^0.20.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.160.0",
    "three-viewport-gizmo": "^2.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.2",
    "vite": "^5.0.10",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-svgr": "^5.2.0"
  },
  "build": {
    "appId": "com.cyberexplorer.astra3dengine",
    "productName": "Astra 3D Engine",
    "copyright": "Copyright © 2024 Cyberexplorer All Rights Reserved.",
    "directories": {
      "output": "release",
      "buildResources": "electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "icon": "electron/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Astra 3D Engine",
      "include": "electron/installer.nsh",
      "license": "LICENSE",
      "artifactName": "${productName}-v${version}-windows-${arch}-setup.exe"
    },
    "portable": {
      "artifactName": "${productName}-v${version}-windows-${arch}-portable.exe"
    },
    "mac": {
      "icon": "electron/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "${productName}-v${version}-macos-${arch}.${ext}"
    },
    "dmg": {
      "icon": "electron/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "icon": "electron/icons",
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "tar.gz",
          "arch": ["x64"]
        }
      ],
      "maintainer": "Astra 3D Team",
      "desktop": {
        "Name": "Astra 3D Engine",
        "Comment": "A 3D engine for creative projects",
        "Categories": "Development;3DGraphics;Graphics"
      },
      "artifactName": "${productName}-v${version}-linux-${arch}.${ext}"
    },
    "appImage": {
      "artifactName": "${productName}-v${version}-linux-${arch}.AppImage"
    },
    "deb": {
      "artifactName": "${productName}-v${version}-linux-${arch}.deb",
      "depends": ["gconf2", "gconf-service", "libnotify4", "libappindicator1"]
    }
  },
  "packageManager": "pnpm@8.15.0"
}
